{
  "name": "@jack-henry/jh-elements",
  "description": "Jack Henry's design system web components.",
  "version": "2.0.0-beta.9",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Banno/jack-henry-design-system.git"
  },
  "type": "module",
  "customElements": "custom-elements.json",
  "web-types": "web-types.json",
  "contributors": [
    "Audrey Bissiere-Grote",
    "Brad McCormick",
    "Maya Buser De"
  ],
  "license": "Apache-2.0",
  "files": [
    "components/**/!(*.stories).js",
    "components/**/*.d.ts",
    "utils",
    "custom-elements.json",
    "web-types.json",
    "jsconfig.json",
    "NOTICE"
  ],
  "scripts": {
    "generate": "hygen component new",
    "storybook": "storybook dev --port 6006",
    "build-storybook": "storybook build",
    "analyze": "cem analyze --config scripts/custom-elements-manifest.config.js && pnpm run postanalyze",
    "postanalyze": "node scripts/clean-web-types-numbers.js",
    "types": "node scripts/generate-declaration-files.js",
    "define": "pnpm run analyze && pnpm run types",
    "prepack": "cp ../../NOTICE .",
    "postpack": "rm -f NOTICE"
  },
  "dependencies": {
    "@jack-henry/jh-tokens": "workspace:2.0.0-beta.8",
    "@jack-henry/jh-icons": "workspace:2.0.0-beta.7",
    "lit": "3.3.1"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "0.10.8",
    "@storybook/addon-a11y": "8.4.6",
    "@storybook/addon-actions": "8.4.6",
    "@storybook/addon-essentials": "8.4.6",
    "@storybook/blocks": "8.4.6",
    "@storybook/manager-api": "8.4.6",
    "@storybook/theming": "8.4.6",
    "@storybook/web-components": "8.4.6",
    "@storybook/web-components-vite": "8.4.6",
    "chromatic": "5.8.3",
    "custom-element-jet-brains-integration": "1.7.0",
    "hygen": "6.2.11",
    "storybook": "8.4.6",
    "storybook-addon-tag-badges": "1.3.1",
    "storybook-dark-mode": "4.0.1",
    "vite": "5.4.12"
  }
}
