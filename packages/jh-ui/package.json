{
  "name": "@jack-henry/jh-ui",
  "description": "Jack Henry's design system web components.",
  "version": "1.15.4",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Banno/jack-henry-design-system.git"
  },
  "customElements": "custom-elements.json",
  "contributors": [
    "Audrey Bissiere-Grote",
    "Brad McCormick",
    "Maya Buser De"
  ],
  "license": "Apache-2.0",
  "files": [
    "components/**/!(*.stories).js",
    "utils",
    "custom-elements.json",
    "index.d.ts",
    "jsconfig.json",
    "NOTICE"
  ],
  "scripts": {
    "generate": "hygen component new",
    "storybook": "storybook dev --port 6006",
    "build-storybook": "storybook build",
    "analyze": "wca analyze components --format json --outFile custom-elements.json",
    "prepack": "cp ../../NOTICE .",
    "postpack": "rm -f NOTICE"
  },
  "dependencies": {
    "@jack-henry/jh-core": "workspace:1.6.0",
    "@jack-henry/jh-icons": "workspace:1.2.0",
    "lit": "2.1.1"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "9.1.20",
    "@storybook/web-components-vite": "9.1.20",
    "chromatic": "5.8.3",
    "hygen": "6.2.11",
    "storybook": "9.1.20",
    "storybook-addon-tag-badges": "2.0.0",
    "web-component-analyzer": "1.1.6",
    "vite": "5.4.12",
    "@storybook/addon-docs": "9.1.20"
  }
}
